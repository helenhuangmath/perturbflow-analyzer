#!/bin/bash
#SBATCH --job-name=write_report_smoke_test
#SBATCH --partition=genoa-std-mem
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --mem=1G
#SBATCH --time=00:02:00
#SBATCH --output=logs/write_report_smoke_test_%j.out
#SBATCH --error=logs/write_report_smoke_test_%j.err

set -euo pipefail

RESULTS_DIR="/vast/projects/wherry/foundation-models-immuno/hhua/sc_perturbation/PerturbScope_v1/results_replogle_weissman_k562_essential_mini20"
OUT="${RESULTS_DIR}/OPEN_THIS_SMOKE_TEST.html"

cat > "${OUT}" <<'HTML'
<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>SMOKE TEST 2026-05-11 14:20</title>
  <style>
    body{font-family:Arial,sans-serif;margin:40px;background:#f8fafc;color:#102033}
    .box{border:4px solid #1f7a4d;background:#ecfff4;padding:24px;border-radius:8px;max-width:900px}
    h1{margin-top:0;color:#145c38}
    code{background:#fff;padding:2px 6px;border:1px solid #cbd5e1}
  </style>
</head>
<body>
  <div class="box">
    <h1>SMOKE TEST FILE IS OPENING</h1>
    <p>If you see this page, your browser is reading files from the correct results folder.</p>
    <p>Generated by Slurm job from <code>write_report_smoke_test.sbatch</code>.</p>
    <p>Timestamp marker: <strong>2026-05-11 14:20</strong></p>
  </div>
</body>
</html>
HTML

ls -lh "${OUT}"
